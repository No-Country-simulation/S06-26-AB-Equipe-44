# ============================================================
# BACKEND — Back/.env
# ============================================================

# Aplicação
APP_ENV=development
APP_PORT=8000
SECRET_KEY=troque-por-uma-chave-segura-e-aleatoria

# Banco de dados
DATABASE_URL=sqlite:///./appbit.db
# Produção PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/appbit

# IA — escolha apenas UM dos dois abaixo
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# Modelo de IA
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2

# Dataset CDRView
CDRVIEW_PATH=app/data/cdrview/visent_cdrview.csv

# CORS (separar por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.vercel.app

# ============================================================
# FRONTEND — Front/.env
# ============================================================

VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Painel BiT
# VITE_MAPBOX_TOKEN=pk...  # Opcional se usar Mapbox
